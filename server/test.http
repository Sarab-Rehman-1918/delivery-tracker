Authorization: Bearer {{token}}


### ─── TEST 5: Create Order ─────────────────
POST {{baseUrl}}/api/orders
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "pickupLocation": {
    "address": "McDonalds Gulberg Lahore",
    "lat": 31.5204,
    "lng": 74.3587
  },
  "dropLocation": {
    "address": "DHA Phase 5 Lahore",
    "lat": 31.4816,
    "lng": 74.4013
  },
  "orderDetails": {
    "items": "Burger, Fries, Drink",
    "totalAmount": 1500
  }
}


### ─── TEST 6: Track Order ──────────────────
GET {{baseUrl}}/api/orders/track/{{trackingId}}


### ─── TEST 7: Update Order Status ──────────
PUT {{baseUrl}}/api/orders/{{orderId}}/status
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "status": "on_the_way"
}

